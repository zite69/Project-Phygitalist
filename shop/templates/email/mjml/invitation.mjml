<mjml version="3.3.3">
  <mj-head>
    <mj-include path="shop/templates/email/mjml/include/head.mjml" />
  </mj-head>
  <mj-body>

    <mj-include path="shop/templates/email/mjml/include/header.mjml" />

    <mj-section mj-class="mail-body">
      <mj-column>
        <mj-text align="center" color="#f66569" font-size="20px" font-weight="bold">
          Invitation to join our site
        </mj-text>
        <mj-text align="center" color="#222" font-size="16px">
          Please click the following link to join our site:
        </mj-text>
        <mj-button background-color="#f66569" color="#ffffff" border-radius="5px" href="{{ signup_url }}" padding="15px 25px">
          Join Now
        </mj-button>
        <mj-text align="center" color="#888888" font-size="14px">
          This link is valid for {{ expiry }}
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-include path="shop/templates/email/mjml/include/footer.mjml" />
  </mj-body>
</mjml>
